# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/notion

# JWT
JWT_SECRET=replace-with-a-long-random-secret

# Redis (OTP storage) — Redis Cloud
REDIS_HOST=redis-12345.c1.us-east1-1.cloud.redislabs.com
REDIS_PORT=12345
REDIS_USERNAME=default
REDIS_PASSWORD=replace-with-redis-cloud-password

# Brevo (transactional email)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=Notion Clone

# OAuth (employee sign-in) — callback URLs to register with each provider:
# http://localhost:3000/api/oauth/google/callback
# http://localhost:3000/api/oauth/github/callback
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Real-time collaboration (standalone WebSocket server, server/collaboration.ts)
COLLAB_PORT=1234
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:1234
